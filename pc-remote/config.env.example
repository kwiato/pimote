# PC Remote configuration. install.sh turns this into the real file
# ~/.config/pc-remote/config.env (kept outside the repo). You can also edit it
# by hand and restart the service: sudo systemctl restart pc-remote.

# MAC of the PC's Ethernet NIC (for Wake-on-LAN). On Windows: ipconfig /all ->
# "Physical Address", replace dashes with colons. Empty = the Wake button
# returns an error, the rest of the panel still works.
PC_MAC=AA:BB:CC:DD:EE:FF

# Address/port the panel listens on. 0.0.0.0 = all interfaces; that's fine
# because every endpoint now requires the panel password or the API token.
REMOTE_HOST=0.0.0.0
REMOTE_PORT=5000

# Keyboard layout active on the Windows side (so typed characters land right):
#   pl = Polish (Programmers): US base + ą/ć/ł… via AltGr
#   us = US English: ASCII only (Polish characters are skipped)
KEYBOARD_LAYOUT=pl

# Path to the ENCRYPTED Windows login password file (created by install.sh,
# chmod 600). It's encrypted with a key derived from your PANEL password, so the
# panel must be unlocked once after each restart before the "Log in" button can
# decrypt it. The app defaults to ~/.config/pc-remote/login.secret.enc — leave
# this commented unless you want a DIFFERENT, ABSOLUTE path (no ~).
# PC_LOGIN_SECRET_FILE=/home/user/.config/pc-remote/login.secret.enc

# Panel password (panel.secret), API token (api.token) and the encrypted
# Windows password (login.secret.enc) also live in ~/.config/pc-remote, all
# created by install.sh. They are NOT set here — they are secrets, not config.
